# Instantly API keys. Copy this file to .env and fill in the real values.
# One key per client workspace. The default key (INSTANTLY_API_KEY) is used
# when InstantlyClient() is constructed without a client= slug. Per-client
# keys follow INSTANTLY_API_KEY_<SLUG> where the slug is uppercased and
# hyphens become underscores (e.g. client="acme-co" -> _ACME_CO).

INSTANTLY_API_KEY=
INSTANTLY_API_KEY_CLIENT_A=
INSTANTLY_API_KEY_CLIENT_B=
